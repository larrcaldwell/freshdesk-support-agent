# --- Required ---------------------------------------------------------------
FRESHDESK_DOMAIN=yourcompany            # yourcompany.freshdesk.com
FRESHDESK_API_KEY=xxxxxxxxxxxxxxxxxxxx  # Freshdesk > Profile Settings > API Key
ANTHROPIC_API_KEY=sk-ant-...
WEBHOOK_SECRET=generate-a-long-random-string

# --- Behavior ----------------------------------------------------------------
# Start with false: everything is drafted as a private note for human review.
# Flip to true once you trust the drafts.
AUTO_REPLY_ENABLED=false
AUTO_REPLY_MIN_CONFIDENCE=85
AUTO_REPLY_CATEGORIES=how-to,account,billing-question,order-status
TRIAGE_ENABLED=true

# Optional: route categories to Freshdesk group IDs
# GROUP_ROUTING_JSON={"billing-question": 123456, "bug-report": 234567}

# --- Voice -------------------------------------------------------------------
COMPANY_NAME=TruDigital
AGENT_SIGNATURE=TruDigital Support

# --- Model -------------------------------------------------------------------
CLAUDE_MODEL=claude-sonnet-5
MAX_TOKENS=4096
KNOWLEDGE_DIR=knowledge
